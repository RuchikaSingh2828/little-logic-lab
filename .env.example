# Sudokid — environment variables
#
# Framework: Next.js 16 (App Router)
#
# Audit (searched app/, components/, features/, lib/):
#   process.env       — not used in application source
#   import.meta.env   — not used (Vite-style; this is not a Vite project)
#   NEXT_PUBLIC_*     — not used
#   VITE_*            — not used
#
# No variables are required to run:
#   npm run dev
#   npm run build
#   npm run start
#
# Setup (when you add configuration later):
#   cp .env.example .env.local
#
# Never commit `.env`, `.env.local`, or real secret values.
# `.env.local` overrides `.env` and is gitignored.

# ── Required ────────────────────────────────────────────────────
# (none — app runs without any env file)

# ── Optional: local development ───────────────────────────────
# PORT=3000

# ── Optional: client-exposed (must be prefixed NEXT_PUBLIC_) ────
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Optional: server-only (set in .env.local or hosting dashboard)
# DATABASE_URL=postgresql://user:password@localhost:5432/little_logic_lab
# API_SECRET_KEY=your-secret-key-here

# ── Optional: hosting (usually set automatically by Vercel) ─────
# VERCEL_URL=
# VERCEL_ENV=
