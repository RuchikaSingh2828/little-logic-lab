# Little Logic Lab — environment variables
#
# Audit (app/, components/, features/, lib/):
#   process.env       — not used
#   import.meta.env   — not used
#   NEXT_PUBLIC_*     — not used
#   VITE_*            — not used
#
# No variables are required to run `npm run dev` or `npm run build`.
#
# Setup (when you add configuration later):
#   cp .env.example .env.local
#
# Never commit `.env`, `.env.local`, or real secret values.

# ── Required ────────────────────────────────────────────────────
# (none)

# ── Optional: local development ───────────────────────────────
# PORT=3000

# ── Optional: client-exposed (must be prefixed NEXT_PUBLIC_) ────
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Optional: server-only secrets (set in .env.local or host) ─
# DATABASE_URL=postgresql://user:password@localhost:5432/little_logic_lab
# API_SECRET_KEY=your-secret-key-here
